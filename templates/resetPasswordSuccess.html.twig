{% extends 'base.html.twig' %}

{% block header %}
    <a href="/">Login</a>
{% endblock %}

{% block content %}

<div style="
    max-width: 700px;
    margin: 40px auto;
    padding: 40px;
    background: rgba(255,255,255,0.9);
    border-radius: 20px;
    text-align: center;
    box-shadow: 0 10px 30px rgba(59,130,246,0.12);
">

    <h1 style="
        font-size: 42px;
        color: #16a34a;
        margin-bottom: 25px;
    ">
        ✅ Contraseña actualizada
    </h1>

    <p style="
        font-size: 19px;
        color: #475569;
        line-height: 1.7;
        margin-bottom: 35px;
    ">
        Tu contraseña se ha actualizado correctamente.
        Ya puedes iniciar sesión con tu nueva contraseña.
    </p>

    <a href="/"
       style="
            display: inline-block;
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            color: white;
            text-decoration: none;
            padding: 14px 28px;
            border-radius: 12px;
            font-size: 17px;
            font-weight: bold;
            box-shadow: 0 5px 15px rgba(59,130,246,0.2);
       ">
        🔐 Ir al login
    </a>

</div>

{% endblock %}
