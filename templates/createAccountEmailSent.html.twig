{% extends 'base.html.twig' %}

{% block header %}
    <a href="/">Login</a>
{% endblock %}

{% block content %}

<div style="
    max-width: 700px;
    margin: 60px auto;
    padding: 40px;
    background: #f8fafc;
    border-radius: 20px;
    text-align: center;
    box-shadow: 0 0 25px rgba(0,0,0,0.08);
">

    <h1 style="
        font-size: 42px;
        color: #16a34a;
        margin-bottom: 20px;
    ">
        📧 Correo enviado
    </h1>

    <p style="
        font-size: 20px;
        color: #334155;
        margin-bottom: 30px;
        line-height: 1.7;
    ">
        Hemos enviado un correo de verificación a:
    </p>

    <div style="
        background: white;
        padding: 18px;
        border-radius: 12px;
        font-size: 22px;
        font-weight: bold;
        color: #0f172a;
        margin-bottom: 35px;
        border: 2px solid #cbd5e1;
        word-break: break-word;
        overflow-wrap: break-word;
    ">
        {{ email }}
    </div>

    <p style="
        color: #64748b;
        font-size: 17px;
        line-height: 1.6;
        margin-bottom: 35px;
    ">
        Revisa tu bandeja de entrada y pulsa el enlace
        de confirmación para activar tu cuenta.
    </p>

    <p style="
        color: #94a3b8;
        font-size: 15px;
        margin-bottom: 35px;
    ">
        Si no encuentras el correo, revisa también la carpeta de spam.
    </p>

    <a href="/"
       style="
            display: inline-block;
            background: #2563eb;
            color: white;
            text-decoration: none;
            padding: 15px 30px;
            border-radius: 12px;
            font-size: 18px;
            font-weight: bold;
       ">
        🔐 Volver al login
    </a>

</div>

{% endblock %}
