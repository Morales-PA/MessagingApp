{% extends 'base.html.twig' %}

{% block header %}
    <a href="/">Login</a>
{% endblock %}

{% block content %}

<div style="
    max-width: 700px;
    margin: 60px auto;
    padding: 40px;
    background: #f8fafc;
    border-radius: 20px;
    text-align: center;
    box-shadow: 0 0 25px rgba(0,0,0,0.08);
">

    {% if success %}

        <h1 style="
            font-size: 42px;
            color: #16a34a;
            margin-bottom: 25px;
        ">
            ✅ Cuenta verificada
        </h1>

    {% else %}

        <h1 style="
            font-size: 42px;
            color: #dc2626;
            margin-bottom: 25px;
        ">
            ❌ Error
        </h1>

    {% endif %}

    <p style="
        font-size: 20px;
        color: #334155;
        margin-bottom: 35px;
        line-height: 1.7;
    ">
        {{ message }}
    </p>

    <a href="/"
       style="
            display: inline-block;
            background: #2563eb;
            color: white;
            text-decoration: none;
            padding: 15px 30px;
            border-radius: 12px;
            font-size: 18px;
            font-weight: bold;
       ">
        🔐 Ir al login
    </a>

</div>

{% endblock %}
